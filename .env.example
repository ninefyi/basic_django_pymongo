# Django Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# MongoDB Atlas Configuration (Cloud)
# Create a free cluster at: https://account.mongodb.com/account
# Get your connection string from MongoDB Atlas and replace the values below
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/blog_db?retryWrites=true&w=majority
