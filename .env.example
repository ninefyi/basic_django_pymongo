# Django Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# MongoDB Atlas Configuration (Cloud)
# Create a free cluster at: https://www.mongodb.com/cloud/atlas
# Get your connection string and replace username, password, and cluster name
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/blog_db?retryWrites=true&w=majority

# For local MongoDB (if you prefer to use local MongoDB)
# MONGODB_URI=mongodb://localhost:27017/blog_db
MONGODB_URI=mongodb://localhost:27017/blog_db
